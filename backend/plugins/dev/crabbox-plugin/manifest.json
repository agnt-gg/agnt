{
  "name": "crabbox-plugin",
  "version": "1.0.0",
  "description": "OpenClaw Crabbox support for remote command execution and E2E proof collection",
  "author": "Yossi Eliaz",
  "icon": "terminal",
  "tools": [
    {
      "type": "crabbox",
      "entryPoint": "./crabbox-api.js",
      "schema": {
        "title": "Crabbox",
        "category": "action",
        "type": "crabbox",
        "icon": "terminal",
        "description": "Run OpenClaw Crabbox commands from AGNT workflows: initialize repo config, run named jobs, lease a remote box, sync the repo, run commands, inspect/list/stop leases, and run doctor checks.",
        "authRequired": "apiKey",
        "authProvider": "crabbox",
        "parameters": {
          "action": {
            "type": "string",
            "inputType": "select",
            "description": "Crabbox action to execute",
            "options": [
              "RUN",
              "WARMUP",
              "JOB_RUN",
              "JOB_LIST",
              "INIT",
              "SYNC_PLAN",
              "STATUS",
              "INSPECT",
              "LIST",
              "STOP",
              "DOCTOR",
              "VERSION"
            ],
            "default": "RUN"
          },
          "command": {
            "type": "string",
            "inputType": "textarea",
            "description": "Command to run remotely after `crabbox run --`. Required for RUN.",
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "shell": {
            "type": "string",
            "inputType": "select",
            "description": "Pass the remote command through Crabbox `--shell` for pipelines or multi-statement scripts.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "workingDirectory": {
            "type": "string",
            "inputType": "text",
            "description": "Local repository path to sync from. Defaults to the AGNT process working directory.",
            "required": false
          },
          "provider": {
            "type": "string",
            "inputType": "text",
            "description": "Optional Crabbox provider such as aws, hetzner, azure, gcp, ssh, or local-container.",
            "required": false
          },
          "leaseId": {
            "type": "string",
            "inputType": "text",
            "description": "Lease id or slug for reuse, status, inspect, stop, or job run.",
            "required": false
          },
          "jobName": {
            "type": "string",
            "inputType": "text",
            "description": "Named Crabbox job to run from `.crabbox.yaml`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "JOB_RUN"
            }
          },
          "profile": {
            "type": "string",
            "inputType": "text",
            "description": "Crabbox profile name.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "ttl": {
            "type": "string",
            "inputType": "text",
            "description": "Maximum lease lifetime, for example 90m or 2h.",
            "default": "90m",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "idleTimeout": {
            "type": "string",
            "inputType": "text",
            "description": "Idle timeout, for example 30m or 90m.",
            "default": "30m",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "className": {
            "type": "string",
            "inputType": "text",
            "description": "Crabbox machine class.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "arch": {
            "type": "string",
            "inputType": "select",
            "description": "CPU architecture.",
            "options": [
              "amd64",
              "arm64"
            ],
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "slug": {
            "type": "string",
            "inputType": "text",
            "description": "Friendly lease slug for a new lease.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "target": {
            "type": "string",
            "inputType": "select",
            "description": "Target operating system.",
            "options": [
              "linux",
              "macos",
              "windows"
            ],
            "required": false,
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "windowsMode": {
            "type": "string",
            "inputType": "select",
            "description": "Windows target mode.",
            "options": [
              "normal",
              "wsl2"
            ],
            "required": false,
            "conditional": {
              "field": "target",
              "value": "windows"
            }
          },
          "network": {
            "type": "string",
            "inputType": "select",
            "description": "Crabbox SSH network path.",
            "options": [
              "auto",
              "tailscale",
              "public"
            ],
            "required": false,
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            }
          },
          "stopAfter": {
            "type": "string",
            "inputType": "select",
            "description": "Crabbox cleanup policy for runs.",
            "options": [
              "success",
              "always",
              "failure",
              "never"
            ],
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "keep": {
            "type": "string",
            "inputType": "select",
            "description": "Keep a newly acquired lease. `warmup` keeps leases by default.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "reclaim": {
            "type": "string",
            "inputType": "select",
            "description": "Reclaim an existing lease claim for this repository.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "keepOnFailure": {
            "type": "string",
            "inputType": "select",
            "description": "Keep a failed one-shot lease for debugging.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "fullResync": {
            "type": "string",
            "inputType": "select",
            "description": "Force a full resync of the remote workdir.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "noSync": {
            "type": "string",
            "inputType": "select",
            "description": "Skip local checkout sync for this run.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "noHydrate": {
            "type": "string",
            "inputType": "select",
            "description": "Skip Crabbox Actions hydration.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "JOB_RUN"
              ]
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "preflight": {
            "type": "string",
            "inputType": "select",
            "description": "Run Crabbox preflight diagnostics before the command.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "debug": {
            "type": "string",
            "inputType": "select",
            "description": "Enable Crabbox debug output.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "timingJson": {
            "type": "string",
            "inputType": "select",
            "description": "Request Crabbox final timing JSON and parse provider/lease proof.",
            "default": "Yes",
            "conditional": {
              "field": "action",
              "value": [
                "RUN",
                "WARMUP"
              ]
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "allowEnv": {
            "type": "string",
            "inputType": "text",
            "description": "Comma-separated env names to forward with Crabbox `--allow-env`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "envFromProfile": {
            "type": "string",
            "inputType": "text",
            "description": "Profile file to load env values from with Crabbox `--env-from-profile`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "label": {
            "type": "string",
            "inputType": "text",
            "description": "Human-readable Crabbox run label.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "preflightTools": {
            "type": "string",
            "inputType": "text",
            "description": "Comma-separated Crabbox preflight tools, for example `default,docker`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "RUN"
            }
          },
          "extraArgs": {
            "type": "string",
            "inputType": "text",
            "description": "Advanced Crabbox CLI flags inserted before the command separator. Do not include `--`.",
            "required": false
          },
          "detect": {
            "type": "string",
            "inputType": "select",
            "description": "Use `crabbox init --detect` to detect repo checks and write a job.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "INIT"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "force": {
            "type": "string",
            "inputType": "select",
            "description": "Use `crabbox init --force` to overwrite generated files.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "INIT"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "configPath": {
            "type": "string",
            "inputType": "text",
            "description": "Custom path for `crabbox init --config`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "INIT"
            }
          },
          "workflowPath": {
            "type": "string",
            "inputType": "text",
            "description": "Custom path for `crabbox init --workflow`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "INIT"
            }
          },
          "skillPath": {
            "type": "string",
            "inputType": "text",
            "description": "Custom path for `crabbox init --skill`.",
            "required": false,
            "conditional": {
              "field": "action",
              "value": "INIT"
            }
          },
          "dryRun": {
            "type": "string",
            "inputType": "select",
            "description": "Preview the expanded Crabbox job without leasing.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "JOB_RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "githubRunner": {
            "type": "string",
            "inputType": "select",
            "description": "Hydrate a job through a GitHub self-hosted runner.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "JOB_RUN"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "stop": {
            "type": "string",
            "inputType": "select",
            "description": "Override Crabbox job stop policy.",
            "options": [
              "auto",
              "always",
              "success",
              "failure",
              "never"
            ],
            "required": false,
            "conditional": {
              "field": "action",
              "value": "JOB_RUN"
            }
          },
          "wait": {
            "type": "string",
            "inputType": "select",
            "description": "Wait for status to settle.",
            "default": "No",
            "conditional": {
              "field": "action",
              "value": "STATUS"
            },
            "options": [
              "Yes",
              "No"
            ]
          },
          "timeoutMs": {
            "type": "number",
            "inputType": "number",
            "description": "Local timeout for the Crabbox process in milliseconds. Defaults to 15 minutes.",
            "default": 900000
          },
          "maxOutputBytes": {
            "type": "number",
            "inputType": "number",
            "description": "Maximum stdout and stderr bytes retained in the AGNT tool result.",
            "default": 200000
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the Crabbox command exited successfully"
          },
          "result": {
            "type": "object",
            "description": "Crabbox command result including args, stdout/stderr, timing JSON, provider, leaseId, runId, and exitCode"
          },
          "error": {
            "type": "string",
            "description": "Error message if the Crabbox command failed"
          }
        }
      }
    }
  ]
}
